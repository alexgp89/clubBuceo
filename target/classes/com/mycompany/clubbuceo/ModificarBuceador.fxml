<StackPane style="-fx-background-color: linear-gradient(to bottom, #0a1628 0%, #0d2744 25%, #0e3d6b 55%, #0b5394 80%, #1a6fad 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.clubbuceo.ModificarBuceadorController">

