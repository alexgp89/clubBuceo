<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<StackPane style="-fx-background-color: linear-gradient(to bottom, #0a1628 0%, #0d2744 25%, #0e3d6b 55%, #0b5394 80%, #1a6fad 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.clubbuceo.EliminarBuceadorController">

    <VBox alignment="TOP_CENTER" spacing="0">
        <padding><Insets bottom="30" left="40" right="40" top="28" /></padding>

        <!-- ── CABECERA ── -->
        <VBox alignment="CENTER" spacing="5">
            <Label style="-fx-font-family: Georgia; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e8f4fd;" text="PUNTA EL POZO" />
            <Label style="-fx-font-family: Georgia; -fx-font-size: 12px; -fx-font-style: italic; -fx-text-fill: #7ecfef;" text="Club de Buceo  -  Eliminar Buceador" />
            <Pane prefHeight="8" />
            <Line endX="420" startX="0" stroke="#2a9fd6" strokeWidth="1.5" />
            <Pane prefHeight="16" />
        </VBox>

        <!-- ── BUSQUEDA POR ID ── -->
        <Label style="-fx-font-family: Verdana; -fx-font-size: 10px; -fx-text-fill: #5ab8e0;" text="BUSCAR BUCEADOR" />
        <Pane prefHeight="10" />

        <HBox alignment="CENTER" spacing="12">

            <Label style="-fx-font-family: Verdana; -fx-font-size: 11px; -fx-text-fill: #a8d8f0;" text="ID del buceador:" />

            <TextField fx:id="txtId" editable="true" prefHeight="36" prefWidth="120" style="-fx-background-color: #ffffff12; -fx-background-radius: 5; -fx-border-color: #2a9fd655; -fx-border-radius: 5; -fx-border-width: 1; -fx-text-fill: #c8e8f8; -fx-font-family: Verdana; -fx-font-size: 11px;" />

            <Button fx:id="btnBuscar" onAction="#Buscar" prefHeight="36" style="-fx-background-color: linear-gradient(to right, #0d6eab, #1a8fc7); -fx-background-radius: 5; -fx-text-fill: #e8f6ff; -fx-font-family: Verdana; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20 8 20;" text="Buscar" />

        </HBox>

        <Pane prefHeight="20" />
        <Line endX="600" startX="0" stroke="#ffffff10" strokeWidth="1" />
        <Pane prefHeight="16" />

        <!-- ── RESULTADO ── -->
        <Label style="-fx-font-family: Verdana; -fx-font-size: 10px; -fx-text-fill: #5ab8e0;" text="DATOS DEL BUCEADOR" />
        <Pane prefHeight="10" />

        <TextArea fx:id="taResultado" editable="false" maxWidth="600.0" prefHeight="300.0" style="-fx-background-color: #ffffff08; -fx-background-radius: 8; -fx-border-color: #2a9fd644; -fx-border-radius: 8; -fx-border-width: 1; -fx-text-fill: #000000; -fx-font-family: Verdana; -fx-font-size: 11px; -fx-control-inner-background: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" />

        <Pane prefHeight="24" />

        <!-- ── BOTONES CONFIRMACION ── -->
        <HBox alignment="CENTER" spacing="16">

            <Button fx:id="btnEliminar" disable="true" onAction="#Eliminar" prefHeight="42" style="-fx-background-color: linear-gradient(to right, #7a1a1a, #b83232); -fx-background-radius: 6; -fx-text-fill: #fff0f0; -fx-font-family: Verdana; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 28 10 28;" text="Confirmar eliminacion" />

            <Button fx:id="btnVolver" onAction="#Volver" prefHeight="42" style="-fx-background-color: transparent; -fx-background-radius: 6; -fx-text-fill: #e8f4fd; -fx-font-family: Verdana; -fx-font-size: 12px; -fx-cursor: hand; -fx-border-color: #e8f4fd; -fx-border-radius: 6; -fx-border-width: 1.5; -fx-padding: 10 24 10 24;" text="Volver al Menu">
            <effect>
               <Glow />
            </effect></Button>

        </HBox>

        <!-- ── PIE ── -->
        <Pane prefHeight="18" />
        <Line endX="420" startX="0" stroke="#2a9fd633" strokeWidth="1" />
        <Pane prefHeight="8" />
        <Label style="-fx-font-family: Verdana; -fx-font-size: 9px; -fx-text-fill: #3a7a9a;" text="© Punta el Pozo · Todos los derechos reservados" />

    </VBox>

</StackPane>
