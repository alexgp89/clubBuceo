<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<StackPane prefHeight="620" prefWidth="1200" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.clubbuceo.MostrarBuceadoresController">

    <!-- ═══════════════════════════════════════════════
         FONDO OCEÁNICO
    ═══════════════════════════════════════════════ -->
    <Pane>
        <style>
            -fx-background-color: linear-gradient(
                to bottom,
                #0a1628 0%,
                #0d2744 25%,
                #0e3d6b 55%,
                #0b5394 80%,
                #1a6fad 100%
            );
        </style>
    </Pane>

    <!-- ═══════════════════════════════════════════════
         CONTENIDO PRINCIPAL
    ═══════════════════════════════════════════════ -->
    <VBox alignment="TOP_CENTER" spacing="0">
        <padding><Insets bottom="24" left="40" right="40" top="28" /></padding>

        <!-- ── CABECERA ── -->
        <VBox alignment="CENTER" spacing="5">
            <Label style="                        -fx-font-family: 'Georgia';                        -fx-font-size: 22px;                        -fx-font-weight: bold;                        -fx-text-fill: #e8f4fd;                        -fx-effect: dropshadow(gaussian, #00c8ff88, 10, 0.4, 0, 2);                    " text="PUNTA EL POZO" />
            <Label style="                        -fx-font-family: 'Georgia';                        -fx-font-size: 12px;                        -fx-font-style: italic;                        -fx-text-fill: #7ecfef;                    " text="Club de Buceo  —  Lista de Buceadores" />
            <Pane prefHeight="8" />
            <Line endX="600" startX="0" stroke="#2a9fd6" strokeWidth="1.5" style="-fx-effect: dropshadow(gaussian, #2a9fd6, 6, 0.5, 0, 0);" />
            <Pane prefHeight="10" />
        </VBox>

        <!-- ── CONTADOR ── -->
        <HBox alignment="CENTER_RIGHT" maxWidth="1120" />

        <Pane prefHeight="8" />

        <!-- ── TABLA ── -->
        <TableView fx:id="tablaBuceadores" prefHeight="440" prefWidth="1120" style="                        -fx-background-color: #ffffff08;                        -fx-background-radius: 8px;                        -fx-border-color: #2a9fd644;                        -fx-border-radius: 8px;                        -fx-border-width: 1px;                        -fx-table-cell-border-color: #ffffff0f;                        -fx-selection-bar: #1a8fc755;                        -fx-selection-bar-non-focused: #1a8fc733;                    " VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colId" prefWidth="50" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="ID" />

                <TableColumn fx:id="colDni" prefWidth="110" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="DNI" />

                <TableColumn fx:id="colNombre" prefWidth="95" style="-fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Nombre" />

                <TableColumn fx:id="colApellidos" prefWidth="120" style="-fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Apellidos" />

                <TableColumn fx:id="colFechaNacimiento" prefWidth="100" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="F. Nacimiento" />

                <TableColumn fx:id="colEmail" prefWidth="155" style="-fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Email" />

                <TableColumn fx:id="colTelefono" prefWidth="90" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Telefono" />

                <TableColumn fx:id="colTitulacion" prefWidth="110" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Titulacion" />

                <TableColumn fx:id="colOrganizacion" prefWidth="60" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Org." />

                <TableColumn fx:id="colInmersiones" prefWidth="50" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Inm." />

                <TableColumn fx:id="colGrupoSanguineo" prefWidth="75" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Gr. Sang." />

                <TableColumn fx:id="colAlergias" prefWidth="100" style="-fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Alergias" />

                <TableColumn fx:id="colReconocimiento" prefWidth="100" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Rec. Medico" />

                <TableColumn fx:id="colCompaniaSeguro" prefWidth="100" style="-fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Comp. Seguro" />

                <TableColumn fx:id="colCaducidadSeguro" prefWidth="100" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Cad. Seguro" />

                <TableColumn fx:id="colContEmergNombre" prefWidth="120" style="-fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Cont. Emerg." />

                <TableColumn fx:id="colContEmergTelf" prefWidth="95" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="Tel. Emerg." />

                <TableColumn fx:id="colFechaAlta" prefWidth="95" style="-fx-alignment: CENTER; -fx-font-family: 'Verdana'; -fx-font-size: 10px;" text="F. Alta" />

            </columns>

            <placeholder>
                <VBox alignment="CENTER" spacing="8">
                    <Label style="                                -fx-font-family: 'Georgia';                                -fx-font-size: 14px;                                -fx-font-style: italic;                                -fx-text-fill: #3a7a9a;                            " text="~ Sin buceadores registrados ~" />
                    <Label style="                                -fx-font-family: 'Verdana';                                -fx-font-size: 10px;                                -fx-text-fill: #2a5a7a;                            " text="Utiliza el menu para anadir nuevos buceadores" />
                </VBox>
            </placeholder>

        </TableView>

        <Pane prefHeight="16" />

        <!-- ── BOTÓN VOLVER ── -->
        <HBox alignment="CENTER">
            <Button fx:id="btnVolver" onAction="#Volver" prefHeight="38" style="-fx-background-color: transparent; -fx-background-radius: 5px; -fx-text-fill: #e8f4fd; -fx-font-family: 'Verdana'; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #e8f4fd; -fx-border-radius: 5px; -fx-border-width: 1.5px; -fx-padding: 8 28 8 28;" text="Volver al Menu" />
        </HBox>

        <!-- ── PIE ── -->
        <Pane prefHeight="14" />
        <Line endX="600" startX="0" stroke="#2a9fd633" strokeWidth="1" />
        <Pane prefHeight="6" />
        <Label style="                    -fx-font-family: 'Verdana';                    -fx-font-size: 9px;                    -fx-text-fill: #3a7a9a;                " text="© Punta el Pozo · Todos los derechos reservados" />

    </VBox>

</StackPane>
